# Jarvis Backend Environment Variables
# Copy this file to .env and fill in your values

# ── Database ─────────────────────────────────────
# DB_TYPE=sqlite  (default — no Docker needed!)
# DB_TYPE=postgres (needs Docker with PostgreSQL)
DB_TYPE=sqlite

# Only needed for DB_TYPE=postgres:
# DATABASE_URL=postgresql+asyncpg://jarvis:jarvis_secret@localhost:5432/jarvis
# DATABASE_URL_SYNC=postgresql://jarvis:jarvis_secret@localhost:5432/jarvis

# Redis (optional, only for production)
USE_REDIS=false
# REDIS_URL=redis://localhost:6379/0

# ── Application ──────────────────────────────────
APP_NAME=Jarvis
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key
API_V1_PREFIX=/api/v1

# ── LLM Provider ─────────────────────────────────
# Options: groq (free), openai (paid), ollama (local)
LLM_PROVIDER=groq

# Groq (free — get key at https://console.groq.com/keys)
GROQ_API_KEY=gsk-your-groq-key-here
GROQ_MODEL=llama-3.1-8b-instant

# OpenAI (only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# ── Voice ────────────────────────────────────────
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
TTS_PROVIDER=openai
TTS_VOICE=alloy
ELEVENLABS_API_KEY=

# ── Authentication ───────────────────────────────
JWT_SECRET=change-me-to-a-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Security ─────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
MAX_REQUEST_SIZE_MB=50
RATE_LIMIT_PER_MINUTE=60

# ── Logging ──────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# ── Monitoring ───────────────────────────────────
ENABLE_METRICS=true
SENTRY_DSN=
