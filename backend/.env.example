# Jarvis Backend Environment Variables
# Copy this file to .env and fill in your values

# ── Application ──────────────────────────────────
APP_NAME=Jarvis
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret-key
API_V1_PREFIX=/api/v1

# ── Database ─────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://jarvis:jarvis_secret@localhost:5432/jarvis
DATABASE_URL_SYNC=postgresql://jarvis:jarvis_secret@localhost:5432/jarvis
REDIS_URL=redis://localhost:6379/0

# ── LLM Provider ─────────────────────────────────
# Options: groq (free), openai (paid), ollama (local)
LLM_PROVIDER=groq

# OpenAI (only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# Groq (free — get key at https://console.groq.com/keys)
GROQ_API_KEY=gsk-your-groq-key-here
GROQ_MODEL=llama-3.1-8b-instant
# Other Groq models: llama-3.1-70b-versatile, mixtral-8x7b-32768, gemma2-9b-it

OPENAI_EMBEDDING_MODEL=text-embedding-ada-002
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# ── Voice ────────────────────────────────────────
# Voice is only available with LLM_PROVIDER=openai
# STT: Whisper
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
# TTS: Options: openai, elevenlabs, edge
TTS_PROVIDER=openai
TTS_VOICE=alloy
ELEVENLABS_API_KEY=

# ── Authentication ───────────────────────────────
JWT_SECRET=change-me-to-a-jwt-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Security ─────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
MAX_REQUEST_SIZE_MB=50
RATE_LIMIT_PER_MINUTE=60

# ── Logging ──────────────────────────────────────
LOG_LEVEL=DEBUG
LOG_FORMAT=json

# ── Monitoring ───────────────────────────────────
ENABLE_METRICS=true
SENTRY_DSN=
